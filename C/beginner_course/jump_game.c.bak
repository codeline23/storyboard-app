#include <stdio.h>
#include <stdlib.h>
#include <conio.h>      // kbhit(), getch() 사용
#include <windows.h>    // Sleep() 사용
#include <time.h>
#include <locale.h>     // 한글 지원

// ESC 키 코드 정의
#define ESC_KEY 27

#define WIDTH 80
#define HEIGHT 20
#define DINO_Y 15

int main() {
    // 콘솔 한글 지원 설정
    system("chcp 65001 > nul");  // UTF-8 활성화
    setlocale(LC_ALL, "");       // 로케일 설정
    
    int dino_x = 5;
    int dino_y = DINO_Y;
    int velocity = 0;           // 점프 속도
    int gravity = 1;            // 중력
    int is_jumping = 0;         // 점프 상태
    
    int obstacle_x = WIDTH - 10;
    int obstacle_y = DINO_Y;
    
    int score = 0;
    int game_over = 0;
    
    char screen[HEIGHT][WIDTH];
    int i, j;
    
    srand((unsigned)time(NULL));
    
    printf("=== 공룡 점프 게임 ===\n");
    printf("스페이스바를 눌러서 점프하세요!\n");
    printf("q를 눌러 게임을 종료합니다.\n\n");
    
    Sleep(2000);
    
    while (!game_over) {
        // 화면 초기화
        for (i = 0; i < HEIGHT; i++) {
            for (j = 0; j < WIDTH; j++) {
                screen[i][j] = ' ';
            }
        }
        
        // 지면 그리기
        for (j = 0; j < WIDTH; j++) {
            screen[DINO_Y + 3][j] = '-';
        }
        
        // 키 입력 처리
        if (kbhit()) {
            char key = getch();
            if (key == ' ' && !is_jumping) {  // 스페이스바 - 점프 시작
                is_jumping = 1;
                velocity = -15;  // 위로 가는 속도
            }
            if (key == 'q' || key == 'Q') {  // q - 게임 종료
                game_over = 1;
                break;
            }
        }
        
        // 점프 물리 계산
        if (is_jumping) {
            velocity += gravity;  // 중력 적용
            dino_y += velocity;
            
            // 지면에 닿으면 점프 종료
            if (dino_y >= DINO_Y) {
                dino_y = DINO_Y;
                is_jumping = 0;
                velocity = 0;
            }
        }
        
        // 공룡 그리기
        if (dino_y >= 0 && dino_y < HEIGHT) {
            screen[dino_y][dino_x] = '@';
        }
        
        // 장애물 이동
        obstacle_x--;
        
        // 장애물 그리기
        if (obstacle_x >= 0 && obstacle_x < WIDTH) {
            screen[obstacle_y][obstacle_x] = '#';
            
            // 충돌 감지
            if (dino_x == obstacle_x && dino_y == obstacle_y) {
                game_over = 1;
                break;
            }
        }
        
        // 장애물이 화면 밖으로 나가면 점수 증가 및 새 장애물 생성
        if (obstacle_x < -5) {
            score++;
            obstacle_x = WIDTH - 5;
            obstacle_y = DINO_Y;  // 장애물 높이를 지면에 고정
        }
        
        // 화면 출력
        system("cls");
        
        // 상단 정보
        printf("점수: %d | 점프: %s | 장애물 X: %d\n", 
               score, 
               is_jumping ? "중" : "가능", 
               obstacle_x);
        printf("================================================================================\n");
        
        // 게임 화면 출력
        for (i = 0; i < HEIGHT; i++) {
            for (j = 0; j < WIDTH; j++) {
                printf("%c", screen[i][j]);
            }
            printf("\n");
        }
        
        printf("================================================================================\n");
        printf("스페이스바: 점프 | q: 종료\n");
        
        // 게임 속도 조절
        Sleep(50);
    }
    
    // 게임 오버 화면
    system("cls");
    printf("\n");
    printf("╔════════════════════════════════════════════════════════════════╗\n");
    printf("║                        게임 오버!                              ║\n");
    printf("║                      최종 점수: %d점                           ║\n", score);
    printf("╚════════════════════════════════════════════════════════════════╝\n");
    printf("\n");
    
    return 0;
}
